---
import Sidebar from '../components/Sidebar.svelte';
import { listPosts, formatDate } from '../lib/posts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

const posts = await listPosts();
const sidebarPosts = posts.map((p) => ({
  slug: p.slug,
  href: p.href,
  title: p.title,
  date: p.date.toISOString(),
  displayDate: formatDate(p.date),
}));

const pageTitle = title === 'exitcondition' ? 'exitcondition' : `${title} — exitcondition`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/par8udz.css" />
  </head>
  <body>
    <header class="fixed top-0 left-0 right-0 z-50 h-16 flex items-center pl-16 pr-6 lg:px-6 border-b border-border bg-background transition-[padding] duration-200">
      <a href="/" class="text-2xl lg:text-3xl tracking-tight text-foreground no-underline hover:text-foreground">
        <span class="font-extrabold">Exit</span><span class="font-normal text-muted-foreground">Condition</span>
      </a>
      <div class="ml-auto flex items-center gap-3">
        <a
          href="https://github.com/ALRubinger"
          target="_blank"
          rel="noopener noreferrer"
          class="github-icon-link inline-flex items-center text-muted-foreground hover:text-foreground transition-colors"
          aria-label="Andrew Lee Rubinger on GitHub"
          title="View on GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor" style="overflow: visible" aria-hidden="true">
            <g class="github-icon-inner">
              <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
            </g>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/alrubinger/"
          target="_blank"
          rel="noopener noreferrer"
          class="linkedin-icon-link inline-flex items-center text-muted-foreground hover:text-foreground transition-colors"
          aria-label="Andrew Lee Rubinger on LinkedIn"
          title="View on LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="overflow: visible" aria-hidden="true">
            <g class="linkedin-icon-inner">
              <path d="M19 0H5C2.24 0 0 2.24 0 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5V5c0-2.76-2.24-5-5-5zM8 19H5V8h3v11zM6.5 6.73c-.97 0-1.75-.79-1.75-1.75S5.53 3.23 6.5 3.23s1.75.79 1.75 1.75-.78 1.75-1.75 1.75zM20 19h-3v-5.6c0-1.34-.03-3.07-1.87-3.07-1.87 0-2.16 1.46-2.16 2.97V19h-3V8h2.88v1.5h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2 3.6 4.59V19z" />
            </g>
          </svg>
        </a>
      </div>
    </header>
    <div class="flex min-h-screen pt-16">
      <Sidebar currentPath={currentPath} posts={sidebarPosts} client:load />

      <!-- min-w-0 keeps long <pre> lines from widening this flex column past
           the viewport; each <pre> scrolls horizontally on its own. -->
      <div class="flex-1 min-w-0">
        <slot />
      </div>
    </div>
    <script is:inline>
      // Page-background parallax. Shifts background-position-y at half the
      // scroll rate so the textured page bg appears to scroll at 50% the
      // speed of content. RAF-throttled; passive listener.
      (function () {
        let ticking = false;
        const update = () => {
          document.body.style.backgroundPositionY = `${window.scrollY * 0.5}px`;
          ticking = false;
        };
        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(update);
            }
          },
          { passive: true },
        );
        update();
      })();
    </script>
    <script>
      // Wire up code-block copy buttons emitted by rehype-copy-button.mjs.
      (function () {
        const RESET_MS = 1500;
        document.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest('button.code-copy-button');
          if (!btn) return;
          const wrapper = btn.closest('.code-block-wrapper');
          if (!wrapper) return;
          const pre = wrapper.querySelector('pre');
          if (!pre) return;
          try {
            await navigator.clipboard.writeText(pre.textContent ?? '');
            btn.classList.add('is-copied');
            btn.setAttribute('aria-label', 'Code copied');
          } catch {
            btn.setAttribute('aria-label', 'Copy failed');
          }
          setTimeout(() => {
            btn.classList.remove('is-copied');
            btn.setAttribute('aria-label', 'Copy code to clipboard');
          }, RESET_MS);
        });
      })();
    </script>
  </body>
</html>
