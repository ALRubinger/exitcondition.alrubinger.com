---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;

const avatarDir = '/src/assets/blog/avatars/';
const avatarPath = avatarDir + author.data.avatar;
// import.meta.glob requires a string literal, so we can't interpolate avatarDir.
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/blog/avatars/*.{jpeg,jpg,png,gif}',
);
if (!images[avatarPath]) {
  throw new Error(`Author avatar "${avatarPath}" does not exist`);
}

const socialX = author.data['social-x'];
const socialLinkedin = author.data['social-linkedin'];
const socialGithub = author.data['social-github'];
---

<div class="author-card flex flex-col sm:flex-row gap-4 items-center sm:items-start">
  <div class="author-card-avatar flex-none">
    <Image
      src={images[avatarPath]()}
      alt={author.data.name}
      width={125}
      height={125}
      class="rounded-full border border-border"
    />
  </div>
  <div class="author-card-meta flex-1 flex items-center">
    <div class="w-full sm:pl-2">
      <div class="author-card-name">{author.data.name}</div>
      <div class="author-card-title">{author.data.title}</div>
      <div class="author-card-socials">
        {socialX && (
          <a
            href={`https://x.com/${socialX}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${author.data.name} on X`}
            class="no-arrow"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        )}
        {socialGithub && (
          <a
            href={`https://github.com/${socialGithub}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${author.data.name} on GitHub`}
            class="no-arrow"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.08 3.29 9.38 7.86 10.9.58.1.79-.25.79-.56 0-.27-.01-1.18-.02-2.13-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.45.11-3.02 0 0 .97-.31 3.18 1.18a11.05 11.05 0 015.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.57.23 2.73.11 3.02.73.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.26 5.69.41.36.78 1.06.78 2.13 0 1.54-.01 2.79-.01 3.17 0 .31.21.67.8.56A11.52 11.52 0 0023.5 12.02C23.5 5.74 18.27.5 12 .5z" />
            </svg>
          </a>
        )}
        {socialLinkedin && (
          <a
            href={`https://linkedin.com/in/${socialLinkedin}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${author.data.name} on LinkedIn`}
            class="no-arrow"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M19 0H5C2.24 0 0 2.24 0 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5V5c0-2.76-2.24-5-5-5zM8 19H5V8h3v11zM6.5 6.73c-.97 0-1.75-.79-1.75-1.75S5.53 3.23 6.5 3.23s1.75.79 1.75 1.75-.78 1.75-1.75 1.75zM20 19h-3v-5.6c0-1.34-.03-3.07-1.87-3.07-1.87 0-2.16 1.46-2.16 2.97V19h-3V8h2.88v1.5h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2 3.6 4.59V19z" />
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .author-card-name {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--foreground);
  }
  .author-card-title {
    font-size: 0.9375rem;
    color: var(--muted-foreground);
    margin-top: 0.125rem;
  }
  .author-card-socials {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    margin-top: 0.625rem;
    color: var(--muted-foreground);
  }
  .author-card-socials a {
    display: inline-flex;
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .author-card-socials a:hover {
    color: var(--foreground);
  }
</style>
