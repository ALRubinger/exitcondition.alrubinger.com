---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import SectionBreak from '../../lib/components/section-break.astro';
import SectionResume from '../../lib/components/section-resume.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) =>
    !import.meta.env.PROD || !data.draft,
  );
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const author = entry.data.author
  ? await getEntry('authors', entry.data.author)
  : undefined;
if (entry.data.author && !author) {
  throw new Error(
    `Post "${entry.id}" references unknown author "${entry.data.author}"`,
  );
}

// SectionBreak / SectionResume are markers consumed by the
// rehype-section-wrapper plugin. They render nothing themselves but
// must be in scope for MDX so authors can use them without an
// explicit import in every file.
const components = { SectionBreak, SectionResume };
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  author={author}
  image={entry.data.image}
  headings={headings}
>
  <Content components={components} />
</PostLayout>
